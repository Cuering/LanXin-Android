# ONNX / embedding models (large binaries, place locally)
app/src/main/assets/models/**
!app/src/main/assets/models/.gitkeep
*.onnx
.idea/copilot.data.migration.ask.xml
.idea/copilot.data.migration.agent.xml
.idea/copilot.data.migration.edit.xml
.idea/copilot.data.migration.ask2agent.xml

# Local LLM weights (Phase 6, do not commit)
*.mnn
*.gguf
*.safetensors

# Offline ASR models / sherpa-onnx (Phase 6.4, do not commit)
**/models/offline-asr/**
**/sherpa-onnx-models/**
libs/sherpa-onnx/**

# Desktop pet commercial / large assets (never commit Meiju dumps)
**/models/tts/**
**/models/live2d/**
# Live2D weights: ban by default; whitelist official Sample Mao only
*.moc3
*.model3.json
!app/src/main/assets/pet/live2d/
!app/src/main/assets/pet/live2d/**
# optional local APK analysis only
*妹居*.apk
meiju_apk_extract/**

# Debug assets: downloaded models stay local (scripts only in git)
# Ignore everything under debug-assets, then re-include keepers.
/debug-assets/*
!/debug-assets/.gitkeep
!/debug-assets/README.md
!/debug-assets/live2d/
!/debug-assets/asr/
!/debug-assets/tts/
/debug-assets/live2d/*
/debug-assets/asr/*
/debug-assets/tts/*
!/debug-assets/live2d/.gitkeep
!/debug-assets/asr/.gitkeep
!/debug-assets/tts/.gitkeep
/debug-assets/.tmp/
app/src/debug/assets/vendor/*
!app/src/debug/assets/vendor/.gitkeep
# common voice / live2d weight dumps (local only)
*.wav
*.mp3
**/sherpa-onnx-*-models/**
